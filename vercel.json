{
  "version": 2,
  "framework": "vite",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/chat",
      "destination": "/api/chat.js"
    },
    {
      "source": "/api/heygen-token",
      "destination": "/api/heygen-token.js"
    },
    {
      "source": "/api/(virtual-lover|companion|senior-care|mental|immortality|rebirth)/chat",
      "destination": "/api/volcengine-chat.js"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        }
      ]
    },
    {
      "source": "/sitemap.xsl",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/xsl"
        }
      ]
    }
  ],
  "functions": {
    "api/chat.js": {
      "maxDuration": 10
    },
    "api/volcengine-chat.js": {
      "maxDuration": 10
    },
    "api/heygen-token.js": {
      "maxDuration": 10
    }
  }
}